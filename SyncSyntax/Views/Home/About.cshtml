@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">

    <!-- Heading -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">About SyncSyntax</h1>
        <p class="lead">
            Welcome to <strong>SyncSyntax</strong> – your trusted source for
            <span class="text-primary">Health, Technology, and Lifestyle</span>.
        </p>
    </div>

    <!-- Cards Section -->
    <div class="row g-4">

        <!-- Health Card -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm border-0 custom-card">
                <div class="card-body">
                    <div class="icon-box bg-danger text-white mb-3">
                        <i class="fas fa-heartbeat"></i>
                    </div>
                    <h5 class="card-title fw-bold">Health</h5>
                    <p class="card-text">
                        Stay informed about the latest health trends, wellness tips,
                        and medical advancements to lead a healthier life.
                    </p>
                </div>
            </div>
        </div>

        <!-- Technology Card -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm border-0 custom-card">
                <div class="card-body">
                    <div class="icon-box bg-info text-white mb-3">
                        <i class="fas fa-microchip"></i>
                    </div>
                    <h5 class="card-title fw-bold">Technology</h5>
                    <p class="card-text">
                        Explore cutting-edge innovations, AI advancements,
                        and tech solutions that shape the future.
                    </p>
                </div>
            </div>
        </div>

        <!-- Lifestyle Card -->
        <div class="col-md-4">
            <div class="card h-100 text-center shadow-sm border-0 custom-card">
                <div class="card-body">
                    <div class="icon-box bg-success text-white mb-3">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h5 class="card-title fw-bold">Lifestyle</h5>
                    <p class="card-text">
                        Get expert advice on personal development, productivity hacks,
                        fashion trends, and mindful living.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- Why Choose Us -->
    <div class="mt-5">
        <div class="card shadow-sm border-0 text-center p-4 custom-card">
            <h3 class="fw-bold mb-3">Why Choose Us?</h3>
            <p>
                At <strong>SyncSyntax</strong>, we bring you well-researched,
                high-quality content to <span class="text-primary fw-semibold">
                    educate, inspire, and empower
                </span> you in your journey towards a better life.
            </p>
        </div>
    </div>

</div>